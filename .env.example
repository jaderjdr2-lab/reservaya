# RESERVAYA — Variables de entorno

# URL pública del sitio (producción: https://reservaya.co)
NEXT_PUBLIC_API_URL="http://localhost:3000"

NODE_ENV="development"

# Supabase PostgreSQL (pooler 6543 + direct 5432)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase Auth (Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Panel admin — solo este email accede a /admin
ADMIN_EMAIL="tu-email@ejemplo.com"

# Wompi (fase 2 — NO configurar hasta tener credenciales sandbox)
# WOMPI_PUBLIC_KEY=
# WOMPI_PRIVATE_KEY=
# WOMPI_EVENTS_SECRET=
# WOMPI_ENV=sandbox

# Google OAuth (opcional — oculto por defecto)
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true
